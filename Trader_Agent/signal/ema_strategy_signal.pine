//@version=5
// EMA25/100 + RSI + EMA200 Daily Macro Filter - Signal Indicator
// LONG  : EMA25 crosses above EMA100 AND RSI(14) < 60
// SHORT : EMA25 crosses below EMA100 AND RSI(14) > 35 AND Bear Macro
// FLAT  : EMA crossunder in Bull Macro (no Short) OR EMA crossover with RSI >= 60 (exit Short)
// Optimized: BTC/USDT 1H 6Y (Binance) | Sharpe 1.437 | Return +5411%

indicator("EMA25/100 + RSI + Macro Filter [Signal]", shorttitle="EMA Signal", overlay=true, max_bars_back=500)

// -- Inputs -------------------------------------------------------------------
ema_fast_len  = input.int(25,  "EMA Fast",         minval=1, group="EMA Settings")
ema_slow_len  = input.int(100, "EMA Slow",         minval=1, group="EMA Settings")
ema_macro_len = input.int(200, "EMA Macro Daily",  minval=1, group="EMA Settings")
rsi_len       = input.int(14,  "RSI Length",       minval=1, group="RSI Settings")
rsi_long_max  = input.int(60,  "RSI Long Max",     minval=1, maxval=100, group="RSI Settings")
rsi_short_min = input.int(35,  "RSI Short Min",    minval=1, maxval=100, group="RSI Settings")

// -- Indicators ---------------------------------------------------------------
ema_fast    = ta.ema(close, ema_fast_len)
ema_slow    = ta.ema(close, ema_slow_len)
rsi_val     = ta.rsi(close, rsi_len)
daily_close = request.security(syminfo.tickerid, "1D", close, lookahead=barmerge.lookahead_off)
ema_200d    = ta.ema(daily_close, ema_macro_len)
is_bull     = close > ema_200d

// -- Signals ------------------------------------------------------------------
long_signal  = ta.crossover(ema_fast, ema_slow)  and rsi_val < rsi_long_max
short_signal = ta.crossunder(ema_fast, ema_slow) and rsi_val > rsi_short_min and not is_bull

// -- Track Position -----------------------------------------------------------
var string pos      = "FLAT"
var string prev_pos = "FLAT"
prev_pos := pos

if long_signal
    pos := "LONG"
else if short_signal
    pos := "SHORT"

// -- Plot EMAs ----------------------------------------------------------------
plot(ema_fast, title="EMA 25",      color=color.new(#58a6ff, 0), linewidth=2)
plot(ema_slow, title="EMA 100",     color=color.new(#ffa657, 0), linewidth=2)
plot(ema_200d, title="EMA 200 Day", color=color.new(#f0e68c, 30), linewidth=1)

// -- Background Color ---------------------------------------------------------
var color bg = na
if pos == "LONG"
    bg := color.new(color.green, 90)
else if pos == "SHORT"
    bg := color.new(color.red, 90)
else
    bg := na
bgcolor(bg, title="Position BG")

// -- Signal Labels ------------------------------------------------------------
// แสดง Label เฉพาะจุดเปลี่ยนตำแหน่ง
if pos == "LONG" and prev_pos != "LONG"
    label.new(bar_index, low,  "LONG",  color=color.new(#3fb950, 10), textcolor=color.white, style=label.style_label_up,   size=size.small)
if pos == "SHORT" and prev_pos != "SHORT"
    label.new(bar_index, high, "SHORT", color=color.new(#ff7b72, 10), textcolor=color.white, style=label.style_label_down, size=size.small)

// -- Info Table ---------------------------------------------------------------
if barstate.islast
    var table t = table.new(position.top_right, 2, 6, bgcolor=color.new(#161b22, 10), border_color=color.new(#30363d, 0), border_width=1, frame_color=color.new(#30363d, 0), frame_width=1)
    sig_color   = pos == "LONG" ? color.new(#3fb950, 0) : pos == "SHORT" ? color.new(#ff7b72, 0) : color.new(#6e7681, 0)
    macro_color = is_bull ? color.new(#3fb950, 0) : color.new(#ff7b72, 0)
    macro_str   = is_bull ? "BULL" : "BEAR"
    table.cell(t, 0, 0, "EMA25/100 Strategy", text_color=color.new(#e6edf3, 0), bgcolor=color.new(#21262d, 0), text_size=size.small)
    table.cell(t, 1, 0, syminfo.ticker,        text_color=color.new(#8b949e, 0), bgcolor=color.new(#21262d, 0), text_size=size.small)
    table.cell(t, 0, 1, "Signal",              text_color=color.new(#8b949e, 0), text_size=size.small)
    table.cell(t, 1, 1, pos,                   text_color=sig_color,             text_size=size.small)
    table.cell(t, 0, 2, "Macro",               text_color=color.new(#8b949e, 0), text_size=size.small)
    table.cell(t, 1, 2, macro_str,             text_color=macro_color,           text_size=size.small)
    table.cell(t, 0, 3, "RSI(14)",             text_color=color.new(#8b949e, 0), text_size=size.small)
    table.cell(t, 1, 3, str.tostring(math.round(rsi_val, 1)), text_color=color.new(#c9d1d9, 0), text_size=size.small)
    table.cell(t, 0, 4, "EMA25 / EMA100",      text_color=color.new(#8b949e, 0), text_size=size.small)
    table.cell(t, 1, 4, str.tostring(math.round(ema_fast, 0)) + " / " + str.tostring(math.round(ema_slow, 0)), text_color=ema_fast > ema_slow ? color.new(#3fb950, 0) : color.new(#ff7b72, 0), text_size=size.small)
    table.cell(t, 0, 5, "EMA200D",             text_color=color.new(#8b949e, 0), text_size=size.small)
    table.cell(t, 1, 5, str.tostring(math.round(ema_200d, 0)), text_color=color.new(#f0e68c, 0), text_size=size.small)

// -- Alert Conditions ---------------------------------------------------------
alertcondition(pos == "LONG" and prev_pos != "LONG",   title="BUY/LONG Signal",  message="BUY/LONG | BTC/USDT 1H | Price: {{close}}")
alertcondition(pos == "SHORT" and prev_pos != "SHORT", title="SELL/SHORT Signal", message="SELL/SHORT | BTC/USDT 1H | Price: {{close}}")
alertcondition(pos != prev_pos,                        title="Any Signal Change", message="Signal Changed to {{plot_0}} | Price: {{close}}")
